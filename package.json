{
  "name": "friend-flow",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "cd frontend && npm install && npm run build && cd .. && wrangler deploy",
    "db:init": "wrangler d1 execute FRIEND_FLOW_DB --file=./schema.sql",
    "build:frontend": "cd frontend && npm run build",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "js-yaml": "^4.1.1"
  }
}
